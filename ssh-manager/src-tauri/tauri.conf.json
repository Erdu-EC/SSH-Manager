{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SSH Explorer",
  "version": "0.1.0",
  "identifier": "dev.erdu.ssh-explorer",
  "build": {
    "beforeDevCommand": "cd src && pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "cd src && pnpm generate",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SSH Explorer",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
